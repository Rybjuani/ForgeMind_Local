# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# PyInstaller
build/
dist/
# Ignoramos specs autogenerados por `pyinstaller --onefile script.py` (patron `*.spec`),
# pero NO el spec del proyecto (forgemind.spec).
auto-*.spec
script.spec
myapp.spec
forge.spec
*.spec
!forgemind.spec

# IDE
.vscode/
.idea/
*.swp

# OS
Thumbs.db
desktop.ini

# Modelos y binarios pesados (NUNCA commitear)
*.gguf
*.bin
*.safetensors
models/
model/

# Resultados de benchmark (se regeneran; mantenemos carpeta trackeada via .gitkeep)
benchmarks/results/*
!benchmarks/results/.gitkeep

# Configs reales (las plantillas .example.json SI se commitean)
configs/*.local.json
configs/*.real.json
configs/models.json
configs/settings.json

# Settings.json del usuario (auto-generado por auto_config.first_run_setup)
# Contiene paths absolutos a la maquina del developer; NUNCA commitear.
settings.json

# Conversaciones de chat persistidas por app/chat_history.py
# (datos del usuario, se regeneran al chatear; NUNCA commitear).
chats/

# Binarios de llama.cpp descargados por app/downloader.py
# (se regeneran via el wizard o `python -m app.downloader cpu`).
bin/

# Vulkan info dump generado por `vulkaninfo --json` (system-specific).
VP_VULKANINFO_*.json

# Screenshots de QA/headless (las del README en screenshots/*.png SI se commitean)
screenshots/smoke-*.png

# Entorno / secretos
.env
.env.*
secrets.*

# Logs
*.log